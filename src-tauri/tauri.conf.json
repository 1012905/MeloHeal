{
  "productName": "MeloHeal",
  "version": "1.0.0",
  "identifier": "com.meloheal.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "MeloHeal 音愈时光",
        "width": 860,
        "height": 780,
        "minWidth": 380,
        "minHeight": 560,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; style-src 'self' 'unsafe-inline'; script-src 'self'; img-src 'self' data: blob:"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "msi", "apk", "app"],
    "icon": ["icons/icon.png", "icons/icon.ico"],
    "windows": {
      "wix": {
        "language": "zh-CN"
      },
      "nsis": {
        "installMode": "currentUser"
      }
    },
    "android": {
      "minSdkVersion": 24
    },
    "ios": {
      "minimumSystemVersion": "15.0"
    }
  },
  "plugins": {}
}
